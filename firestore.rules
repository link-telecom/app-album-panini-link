rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function areFriends(uidA, uidB) {
      let sorted = uidA < uidB ? [uidA, uidB] : [uidB, uidA];
      return exists(/databases/$(database)/documents/friendships/$(sorted[0] + '__' + sorted[1]));
    }

    // Perfiles de usuario
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSelf(uid)
                    && request.resource.data.keys().hasOnly(['username', 'displayName', 'createdAt'])
                    && request.resource.data.username is string
                    && request.resource.data.displayName is string;
      allow update: if isSelf(uid)
                    && request.resource.data.username == resource.data.username;
      allow delete: if false;

      // Sub-colección de láminas por usuario
      match /stickers/{stickerCode} {
        allow read: if isSelf(uid) || areFriends(request.auth.uid, uid);
        allow write: if isSelf(uid)
                     && request.resource.data.count is number
                     && request.resource.data.count >= 0
                     && request.resource.data.count <= 999;
      }
    }

    // Índice de usernames para validar unicidad y búsqueda
    // Lectura pública: necesaria para validar disponibilidad antes del registro,
    // y los usernames son públicos por diseño (los amigos te encuentran).
    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Amistades
    match /friendships/{friendshipId} {
      allow read: if isSignedIn()
                  && request.auth.uid in resource.data.users;
      allow create: if isSignedIn()
                    && request.auth.uid in request.resource.data.users
                    && request.resource.data.users.size() == 2;
      allow delete: if isSignedIn()
                    && request.auth.uid in resource.data.users;
      allow update: if false;
    }
  }
}
